{
  "TaskManager": {
    "ConnectionString": "ALA_MA_KOTA" 
  },
  "NLog": {
    "targets": {
      "async": true,
      "file": {
        "type": "File",
        "fileName": "${specialfolder:CommonApplicationData}/TaskManager/Logs/${shortdate}.log"
      }
    },
    "rules": [
      {
        "logger": "*",
        "minLevel": "Trace",
        "writeTo": "file"
      }
    ]
  }
}
